APP_ENV=development
APP_PORT=8080
WORKER_METRICS_PORT=9091
LOG_LEVEL=debug

DATABASE_URL=postgres://postgres:postgres@localhost:5432/payment_platform?sslmode=disable
DASHBOARD_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=
MIDTRANS_API_BASE_URL=https://api.sandbox.midtrans.com/v2
MIDTRANS_HTTP_TIMEOUT=30s

JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
TOKEN_PEPPER=dev-token-pepper
MFA_ENCRYPTION_KEY=dev-mfa-encryption-key
WEBHOOK_SIGNING_PEPPER=dev-webhook-pepper
STORE_CALLBACK_HTTP_TIMEOUT=15s

HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=30s
HEALTHCHECK_TIMEOUT=2s
SHUTDOWN_TIMEOUT=10s
WORKER_CONCURRENCY=10

MIGRATIONS_DIR=db/migrations
