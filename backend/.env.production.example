APP_ENV=production
APP_PORT=18080
WORKER_METRICS_PORT=19091
LOG_LEVEL=info

DATABASE_URL=postgres://payment_platform:change-me@127.0.0.1:5432/payment_platform?sslmode=disable
DASHBOARD_DIST_DIR=/opt/payment-platform/current/dashboard/dist
DASHBOARD_ALLOWED_ORIGINS=https://paygate.example.com

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

MIDTRANS_ENV=production
MIDTRANS_SERVER_KEY=Mid-server-change-me
MIDTRANS_API_BASE_URL=https://api.midtrans.com/v2
MIDTRANS_OVERRIDE_NOTIFICATION_URLS=
MIDTRANS_HTTP_TIMEOUT=30s

JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
TOKEN_PEPPER=change-me
MFA_ENCRYPTION_KEY=change-me
WEBHOOK_SIGNING_PEPPER=change-me
ALERT_ENDPOINT_PEPPER=change-me

STORE_CALLBACK_HTTP_TIMEOUT=15s
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=30s
HEALTHCHECK_TIMEOUT=2s
SHUTDOWN_TIMEOUT=10s
WORKER_CONCURRENCY=10

MIGRATIONS_DIR=/opt/payment-platform/current/db/migrations
